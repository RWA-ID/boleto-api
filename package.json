  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "hardhat": "^2.22.0",
    "@openzeppelin/contracts": "^5.0.0",
    "typescript": "^5.5.0",
    "@types/node": "^22.0.0",
    "dotenv": "^16.4.5"
  }
}
