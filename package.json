{
  "name": "boleto-eth",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "api",
    "dashboard"
  ],
  "scripts": {
    "dev:api": "cd api && npm run dev",
    "dev:dashboard": "cd dashboard && npm run dev",
